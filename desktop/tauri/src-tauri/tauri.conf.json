{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "逐字搞定 Beta",
  "version": "0.1.2-beta",
  "identifier": "com.minrui.scribby",
  "build": {
    "beforeDevCommand": "npm run dev:web",
    "beforeBuildCommand": "npm run build:web",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../../frontend/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "逐字搞定 Beta",
        "width": 1120,
        "height": 920,
        "minWidth": 900,
        "minHeight": 760,
        "resizable": true,
        "decorations": true,
        "hiddenTitle": true,
        "titleBarStyle": "Overlay",
        "trafficLightPosition": {
          "x": 18,
          "y": 18
        }
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "app",
    "resources": [
      "../../../desktop/python_backend.py",
      "../../../desktop/ipc_protocol.py",
      "../../../desktop/adapters",
      "../../../desktop/runtime/python",
      "../../../engine.py",
      "../../../transcribe_worker.py",
      "../../../runtime_paths.py"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "13.0"
    }
  }
}
